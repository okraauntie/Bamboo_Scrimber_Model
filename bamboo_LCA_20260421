    c: ModelConstants = C,
) -> float:
    initial_stock = calculate_initial_biogenic_stock(c)
    if initial_stock <= 0:
        return 0.0
    retained_mass_fraction = retained_stock_kgco2e / initial_stock
    return c.functional_unit_kg * retained_mass_fraction
    
def _make_stage(
    stage: str,
    *,
    process: float = 0.0,
    release: float = 0.0,
    stock_end: float = 0.0,
    stock_change: float = 0.0,
    notes: str = "",
    transport: float = 0.0,
    electricity: float = 0.0,
    steam: float = 0.0,
    resin: float = 0.0,
    harvesting: float = 0.0,
    start_year: Optional[float] = None,
    end_year: Optional[float] = None,
) -> StageRecord:
    return StageRecord(
        stage_code=stage,
        stage_label=stage,
        process_emissions_kgco2e=process,
        biogenic_release_kgco2e=release,
        retained_stock_kgco2e=stock_end,
        stock_change_kgco2e=stock_change,
        transport_emissions_kgco2e=transport,
        electricity_emissions_kgco2e=electricity,
        steam_emissions_kgco2e=steam,
        resin_emissions_kgco2e=resin,
        harvesting_emissions_kgco2e=harvesting,
        start_year=start_year,
        end_year=end_year,
        notes=notes,
    )


def _sum(*xs: float) -> float:
    return sum(xs)


def _per_kg(x_per_m3: float, c: ModelConstants) -> float:
    return x_per_m3 / c.density_kg_per_m3


def transport_emissions(
    mass_kg: float,
    distance_km: float,
    ef_kgco2e_per_tkm: float,
    c: ModelConstants = C,
) -> float:
    if min(mass_kg, distance_km, ef_kgco2e_per_tkm) < 0:
        raise ValueError("mass_kg, distance_km, and ef_kgco2e_per_tkm must be >= 0.")
    base_emissions = (mass_kg / 1000.0) * distance_km * ef_kgco2e_per_tkm
    return base_emissions * c.transport_emissions_multiplier


def ev_transport_from_tkm(
    tkm_per_m3: float,
    payload_t: float,
    kwh_per_km: float,
    grid_ef: float,
    charging_loss_factor: float = 1.0,
    c: ModelConstants = C,
) -> Dict[str, float]:
    if tkm_per_m3 < 0 or kwh_per_km < 0 or grid_ef < 0 or payload_t <= 0 or charging_loss_factor <= 0:
        raise ValueError("Invalid EV transport inputs.")
    vehicle_km_per_m3 = tkm_per_m3 / payload_t
    electricity_kwh_per_m3 = vehicle_km_per_m3 * kwh_per_km * charging_loss_factor
    kgco2e_per_m3 = electricity_kwh_per_m3 * grid_ef * c.transport_emissions_multiplier
    kgco2e_per_tkm = (kwh_per_km * charging_loss_factor * grid_ef * c.transport_emissions_multiplier) / payload_t
    return {
        "vehicle_km_per_m3": vehicle_km_per_m3,
        "electricity_kwh_per_m3": electricity_kwh_per_m3,
        "kgco2e_per_m3": kgco2e_per_m3,
        "kgco2e_per_tkm": kgco2e_per_tkm,
        "kgco2e_per_kgkm": kgco2e_per_tkm / 1000.0,
    }


def _terminal_year(stage: StageRecord) -> float:
    if stage.stage_code == "D1":
        return 25.0
    if stage.stage_code == "D2":
        return 25.0
    if stage.stage_code in {"D3", "E3"}:
        return 50.0
    raise ValueError(
        f"_terminal_year() only supports D-stage records (D1/D2/D3), "
        f"got '{stage.stage_code}'."
    )


# -----------------------------
# Decay functions
# -----------------------------

def bamboo_decay_no_maintenance_remaining(
    initial_stock: float, 
    years: float, 
    retention_at_year_25: float = D1_RETENTION_AT_YEAR_2
) -> float:
    """Calculate remaining stock using piece-wise decay with custom endpoint retention."""
    if initial_stock < 0 or years < 0:
        raise ValueError("initial_stock and years must be >= 0.")
    if not (0 < retention_at_year_25 <= 1):
        raise ValueError("retention_at_year_25 must be between 0 and 1.")
    
    y1 = D1_RETENTION_AT_YEAR_1 * initial_stock
    y2 = retention_at_year_25 * initial_stock
    k1 = log(initial_stock / y1) / D1_REFERENCE_YEAR_1
    k2 = log(y1 / y2) / (D1_REFERENCE_YEAR_2 - D1_REFERENCE_YEAR_1)
    return initial_stock * exp(-k1 * years) if years <= D1_REFERENCE_YEAR_1 else y1 * exp(-k2 * (years - D1_REFERENCE_YEAR_1))

def bamboo_decay_fraction_d1(year: float) -> float:
    if year < 0:
        raise ValueError("year must be >= 0.")
    k1 = log(1.0 / D1_RETENTION_AT_YEAR_1) / D1_REFERENCE_YEAR_1
    k2 = log(D1_RETENTION_AT_YEAR_1 / D1_RETENTION_AT_YEAR_2) / (D1_REFERENCE_YEAR_2 - D1_REFERENCE_YEAR_1)
    return exp(-k1 * year) if year <= D1_REFERENCE_YEAR_1 else D1_RETENTION_AT_YEAR_1 * exp(-k2 * (year - D1_REFERENCE_YEAR_1))


def continue_decay_from_stage_c_d1(carbon_at_year1: float, stage_d_duration_years: float) -> float:
    if carbon_at_year1 < 0 or stage_d_duration_years < 0:
        raise ValueError("carbon_at_year1 and stage_d_duration_years must be >= 0.")
    start_year, end_year = 1.0, 1.0 + stage_d_duration_years
    return carbon_at_year1 * (bamboo_decay_fraction_d1(end_year) / bamboo_decay_fraction_d1(start_year))


def bamboo_decay_fraction_d3(year: float, retention_50y: float) -> float:
    """
    Linear decay from 100% retention at year 0
    to retention_50y at year 50, independent of D1.
    """
    if year < 0 or not (0 < retention_50y <= 1):
        raise ValueError("Invalid D3 decay inputs.")

    if year <= 50.0:
        return 1.0 + (retention_50y - 1.0) * (year / 50.0)

    return retention_50y


def continue_decay_direct_d3(initial_stock: float, end_year: float, retention_50y: float) -> float:
    if initial_stock < 0 or end_year < 0 or not (0 < retention_50y <= 1):
        raise ValueError("Invalid D3 continuation inputs.")
    return initial_stock * bamboo_decay_fraction_d3(end_year, retention_50y)


# D2 uses the same piece-wise decay as D1 (6y @ 0.94, then to 0.50 at 25y)
# No separate D2 decay function needed - use bamboo_decay_no_maintenance_remaining directly


# -----------------------------
# Stage D1 (Relocation pathway - from Stage C)
# -----------------------------

def _relocation_transport(mass_kg: float, c: ModelConstants) -> float:
    return _sum(
        transport_emissions(mass_kg, c.osaka_expo_to_port_km, c.truck_kgco2e_per_tkm, c),
        transport_emissions(mass_kg, c.osaka_to_haikou_km, c.ship_kgco2e_per_tkm, c),
        transport_emissions(mass_kg, c.haikou_port_to_site_km, c.truck_kgco2e_per_tkm, c),
    )


def calculate_stage_d1(stage_c: StageRecord, c: ModelConstants = C) -> StageRecord:
    start_stock = stage_c.retained_stock_kgco2e
    remaining_mass = remaining_product_mass_from_stock(start_stock, c)

    process = _relocation_transport(remaining_mass, c)
    stock_end = continue_decay_from_stage_c_d1(start_stock, c.d1_secondary_service_life_years)
    release = start_stock - stock_end

    return _make_stage(
        "D1",
        process=process,
        release=release,
        stock_end=stock_end,
        stock_change=-release,
        notes="Relocation from Osaka to Hainan using remaining product mass after Stage C + 24-year secondary service life in Hainan.",
        transport=process,
        start_year=1.0,
        end_year=25.0,
    )


# -----------------------------
# Stage D2 (Direct deployment - from Stage A, 25-year life)
# -----------------------------

def _direct_transport(mass_kg: float, c: ModelConstants) -> float:
    return _sum(
        transport_emissions(mass_kg, c.d23_truck1_distance_km, c.truck_kgco2e_per_tkm, c),
        transport_emissions(mass_kg, c.d23_ferry_distance_km, c.d23_ferry_kgco2e_per_tkm, c),
        transport_emissions(mass_kg, c.d23_truck2_distance_km, c.truck_kgco2e_per_tkm, c),
    )


def calculate_stage_d2(stage_a: StageRecord, c: ModelConstants = C) -> StageRecord:
    start_stock = stage_a.retained_stock_kgco2e
    remaining_mass = remaining_product_mass_from_stock(start_stock, c)

    process = _direct_transport(remaining_mass, c)
    stock_end = bamboo_decay_no_maintenance_remaining(
        start_stock,
        c.d2_service_life_years,
        c.d2_retention_at_year_25
    )
    release = start_stock - stock_end

    return _make_stage(
        "D2",
        process=process,
        release=release,
        stock_end=stock_end,
        stock_change=-release,
        notes=f"Direct deployment from Zhejiang to Hainan using remaining product mass + 25-year secondary service life with {c.d2_retention_at_year_25:.0%} retention at year 25.",
        transport=process,
        start_year=0.0,
        end_year=25.0,
    )


# -----------------------------
# Stage D3 (Direct deployment - from Stage A, 50-year life) - WITH EV TRANSPORT
# -----------------------------

def _direct_transport_d3_ev(mass_kg: float, c: ModelConstants) -> float:
    mass_tonnes = mass_kg / 1000.0

    tkm_leg1 = mass_tonnes * c.d23_truck1_distance_km
    vehicle_km_leg1 = tkm_leg1 / (c.d3_ev_truck_payload_kg / 1000.0)
    electricity_kwh_leg1 = vehicle_km_leg1 * c.d3_ev_truck_kwh_per_km * c.d3_ev_charging_loss_factor
    emissions_leg1 = electricity_kwh_leg1 * c.zhejiang_grid_kgco2e_per_kwh * c.transport_emissions_multiplier

    emissions_leg2 = transport_emissions(
        mass_kg,
        c.d23_ferry_distance_km,
        c.d23_ferry_kgco2e_per_tkm,
        c
    )

    tkm_leg3 = mass_tonnes * c.d23_truck2_distance_km
    vehicle_km_leg3 = tkm_leg3 / (c.d3_ev_truck_payload_kg / 1000.0)
    electricity_kwh_leg3 = vehicle_km_leg3 * c.d3_ev_truck_kwh_per_km * c.d3_ev_charging_loss_factor
    emissions_leg3 = electricity_kwh_leg3 * c.hainan_grid_kgco2e_per_kwh * c.transport_emissions_multiplier

    return emissions_leg1 + emissions_leg2 + emissions_leg3


def calculate_stage_d3(stage_a: StageRecord, c: ModelConstants = C) -> StageRecord:
    start_stock = stage_a.retained_stock_kgco2e
    remaining_mass = remaining_product_mass_from_stock(start_stock, c)

    process = _direct_transport_d3_ev(remaining_mass, c)
    stock_end = continue_decay_direct_d3(start_stock, c.d3_end_of_service_year, c.d3_target_retention_fraction_at_year50)
    release = start_stock - stock_end

    return _make_stage(
        "D3",
        process=process,
        release=release,
        stock_end=stock_end,
        stock_change=-release,
        notes="Direct deployment from Zhejiang to Hainan using remaining product mass + 50-year secondary service life with EV transport.",
        transport=process,
        start_year=0.0,
        end_year=50.0,
    )


# -----------------------------
# Stage A
# -----------------------------

def calculate_initial_biogenic_stock(c: ModelConstants = C) -> float:
    bamboo_mass = c.functional_unit_kg * c.bamboo_fraction
    carbon_mass = bamboo_mass * c.carbon_fraction_bamboo_dry
    return carbon_mass * c.co2_to_c_molecular_ratio


def calculate_stage_a(c: ModelConstants = C) -> StageRecord:
    stock = calculate_initial_biogenic_stock(c)
    return _make_stage("A", stock_end=stock, stock_change=stock, notes="Initial biogenic carbon stock.", start_year=0.0, end_year=0.0)


# -----------------------------
# Stage B
# -----------------------------

def _stage_b_workload(c: ModelConstants = C) -> Dict[str, float]:
    bamboo_mass = c.density_kg_per_m3 * c.bamboo_fraction
    resin_mass = c.density_kg_per_m3 * c.resin_fraction
    bamboo_input_fp = bamboo_mass / c.recovery_rate_fp
    bamboo_input_cp = bamboo_input_fp / c.recovery_rate_cp
    residue = bamboo_input_cp - bamboo_mass
    electricity = c.bundle_electricity_kwh_per_m3 + c.final_beam_electricity_kwh_per_m3
    steam = c.bundle_steam_kwh_per_m3 / c.recovery_rate_ep
    return {
        "bamboo_mass_kg_per_m3": bamboo_mass,
        "resin_mass_kg_per_m3": resin_mass,
        "bamboo_input_fp_kg_per_m3": bamboo_input_fp,
        "bamboo_input_cp_kg_per_m3": bamboo_input_cp,
        "residue_generated_kg_per_m3": residue,
        "total_electricity_kwh_per_m3": electricity,
        "steam_input_kwh_per_m3": steam,
        "transport1_tkm_per_m3": (bamboo_input_cp / 1000.0) * c.transport1_distance_km_stage_b,
        "transport2_tkm_per_m3": (bamboo_input_fp / 1000.0) * c.transport2_distance_km_stage_b,
    }


def _build_stage_b(
    stage: str,
    c: ModelConstants,
    notes: str,
    *,
    harvesting_per_m3: float,
    electricity_per_m3: float,
    steam_per_m3: float,
    resin_per_m3: float,
    transport_per_m3: float,
) -> StageRecord:
    total = harvesting_per_m3 + electricity_per_m3 + steam_per_m3 + resin_per_m3 + transport_per_m3
    return _make_stage(
        stage,
        process=_per_kg(total, c),
        stock_end=0.0,
        stock_change=0.0,
        notes=notes,
        transport=_per_kg(transport_per_m3, c),
        electricity=_per_kg(electricity_per_m3, c),
        steam=_per_kg(steam_per_m3, c),
        resin=_per_kg(resin_per_m3, c),
        harvesting=_per_kg(harvesting_per_m3, c),
        start_year=0.0,
        end_year=0.0,
    )


def calculate_stage_b1(c: ModelConstants = C) -> StageRecord:
    w = _stage_b_workload(c)
    return _build_stage_b(
        "B1",
        c,
        "Baseline manufacturing emissions using recovery-rate-adjusted upstream bamboo inputs and transport tonne-km.",
        harvesting_per_m3=c.harvesting_machine_hours_per_m3 * c.harvesting_kgco2e_per_hr_power_saw,
        electricity_per_m3=w["total_electricity_kwh_per_m3"] * c.electricity_kgco2e_per_kwh,
        steam_per_m3=w["steam_input_kwh_per_m3"] * c.steam_kgco2e_per_kwh,
        resin_per_m3=w["resin_mass_kg_per_m3"] * c.phenolic_resin_kgco2e_per_kg,
        transport_per_m3=_sum(
            w["transport1_tkm_per_m3"] * c.transport1_kgco2e_per_tkm_stage_b,
            w["transport2_tkm_per_m3"] * c.transport2_kgco2e_per_tkm_stage_b,
        ),
    )


def calculate_stage_b2(c: ModelConstants = C) -> StageRecord:
    w = _stage_b_workload(c)
    grid_kwh = w["total_electricity_kwh_per_m3"] * (1.0 - c.pv_substitution_share)
    small = ev_transport_from_tkm(w["transport1_tkm_per_m3"], c.small_lorry_payload_t, c.ev_small_lorry_kwh_per_km, c.electricity_kgco2e_per_kwh, c.charging_loss_factor, c)
    heavy = ev_transport_from_tkm(w["transport2_tkm_per_m3"], c.heavy_lorry_payload_t, c.ev_heavy_lorry_kwh_per_km, c.electricity_kgco2e_per_kwh, c.charging_loss_factor, c)
    return _build_stage_b(
        "B2",
        c,
        "Green energy scenario using baseline B1 transport tonne-km, rooftop PV substitution, and EV transport conversion.",
        harvesting_per_m3=c.harvesting_machine_hours_per_m3 * c.harvesting_kgco2e_per_hr_power_saw,
        electricity_per_m3=grid_kwh * c.electricity_kgco2e_per_kwh,
        steam_per_m3=w["steam_input_kwh_per_m3"] * c.steam_kgco2e_per_kwh,
        resin_per_m3=w["resin_mass_kg_per_m3"] * c.phenolic_resin_kgco2e_per_kg,
        transport_per_m3=_sum(small["kgco2e_per_m3"], heavy["kgco2e_per_m3"]),
    )


def calculate_stage_b3(c: ModelConstants = C) -> StageRecord:
    w = _stage_b_workload(c)
    grid_kwh = w["total_electricity_kwh_per_m3"] * (1.0 - c.pv_substitution_share)
    residue_tkm = (w["residue_generated_kg_per_m3"] / 1000.0) * c.transport1_distance_km_stage_b
    small = ev_transport_from_tkm(w["transport1_tkm_per_m3"] + residue_tkm, c.small_lorry_payload_t, c.ev_small_lorry_kwh_per_km, c.electricity_kgco2e_per_kwh, c.charging_loss_factor, c)
    heavy = ev_transport_from_tkm(w["transport2_tkm_per_m3"], c.heavy_lorry_payload_t, c.ev_heavy_lorry_kwh_per_km, c.electricity_kgco2e_per_kwh, c.charging_loss_factor, c)
    
    # Calculate blended resin emission factor based on lignin substitution rate
    # substitution_rate = 1.0 → 100% lignin resin (EF = 2.18)
    # substitution_rate = 0.0 → 100% phenolic resin (EF = 3.13)
    blended_resin_ef = (c.phenolic_resin_kgco2e_per_kg * (1 - c.lignin_substitution_rate) + 
                         c.lignin_resin_kgco2e_per_kg * c.lignin_substitution_rate)
    
    return _build_stage_b(
        "B3",
        c,
        f"Green inputs scenario using {c.pv_substitution_share:.0%} PV substitution, {c.lignin_substitution_rate:.0%} lignin resin, residue-fired steam replacement, and extra residue transport on the small-lorry EV leg.",
        harvesting_per_m3=c.harvesting_machine_hours_per_m3 * c.harvesting_kgco2e_per_hr_power_saw,
        electricity_per_m3=grid_kwh * c.electricity_kgco2e_per_kwh,
        steam_per_m3=0.0,
        resin_per_m3=w["resin_mass_kg_per_m3"] * blended_resin_ef,  
        transport_per_m3=_sum(small["kgco2e_per_m3"], heavy["kgco2e_per_m3"]),
    )


B_STAGE_FUNCS = {"B1": calculate_stage_b1, "B2": calculate_stage_b2, "B3": calculate_stage_b3}


def calculate_stage_b(stage_code: str, c: ModelConstants = C) -> StageRecord:
    try:
        return B_STAGE_FUNCS[stage_code](c)
    except KeyError as e:
        raise ValueError(f"Unsupported Stage B code: {stage_code}") from e


# -----------------------------
# Stage C and C1
# -----------------------------

def calculate_stage_c(stage_a: StageRecord, c: ModelConstants = C) -> StageRecord:
    initial_stock = stage_a.retained_stock_kgco2e
    process = _sum(
        transport_emissions(c.functional_unit_kg, c.stage_c_transport1_distance_km, c.truck_kgco2e_per_tkm, c),
        transport_emissions(c.functional_unit_kg, c.stage_c_transport2_distance_km, c.ship_kgco2e_per_tkm, c),
        transport_emissions(c.functional_unit_kg, c.stage_c_transport3_distance_km, c.truck_kgco2e_per_tkm, c),
    )
    stock_end = bamboo_decay_no_maintenance_remaining(initial_stock, c.stage_c_project_duration_years)
    release = initial_stock - stock_end
    return _make_stage(
        "C",
        process=process,
        release=release,
        stock_end=stock_end,
        stock_change=-release,
        notes="Export transport + 1-year decay in Osaka.",
        transport=process,
        start_year=0.0,
        end_year=1.0,
    )


def calculate_stage_c1(stage_a: StageRecord, stage_c: StageRecord, c: ModelConstants = C) -> StageRecord:
    initial_stock = stage_a.retained_stock_kgco2e
    stock_before = stage_c.retained_stock_kgco2e
    retained_mass_fraction = 0.0 if initial_stock <= 0 else stock_before / initial_stock
    remaining_mass = c.functional_unit_kg * retained_mass_fraction
    process = transport_emissions(remaining_mass, c.stage_c1_transport4_distance_km, c.truck_kgco2e_per_tkm, c)
    return _make_stage(
        "C1",
        process=process,
        release=stock_before,
        stock_end=0.0,
        stock_change=-stock_before,
        notes="Disposal in Osaka using remaining product mass after year-1 decay.",
        transport=process,
        start_year=1.0,
        end_year=1.0,
    )


# -----------------------------
# Stage E1, E2, E3
# -----------------------------

def _end_of_life_ev_transport(mass_kg: float, c: ModelConstants = C) -> float:
    electricity = (
        c.west_coast_park_to_incinerator_km
        * c.ev_heavy_lorry_kwh_per_km
        * (mass_kg / c.heavy_lorry_payload_kg_e1)
    )
    return electricity * c.hainan_grid_kgco2e_per_kwh * c.transport_emissions_multiplier


def calculate_stage_e1(stage_d: StageRecord, c: ModelConstants = C) -> StageRecord:
    entering = stage_d.retained_stock_kgco2e
    remaining_mass = remaining_product_mass_from_stock(entering, c)
    process = _end_of_life_ev_transport(remaining_mass, c)
    yr = _terminal_year(stage_d)

    return _make_stage(
        "E1",
        process=process,
        release=entering,
        stock_end=0.0,
        stock_change=-entering,
        notes="Hainan transport using remaining product mass + full incineration.",
        transport=process,
        start_year=yr,
        end_year=yr,
    )


def _calculate_stage_biochar(
    stage: str,
    stage_d: StageRecord,
    retention: float,
    notes: str,
    c: ModelConstants = C,
) -> StageRecord:
    entering = stage_d.retained_stock_kgco2e
    remaining_mass = remaining_product_mass_from_stock(entering, c)
    transport_process = _end_of_life_ev_transport(remaining_mass, c)

    stock_end = entering * retention
    release = entering - stock_end
    yr = 50.0 if stage == "E3" else _terminal_year(stage_d)

    return _make_stage(
        stage,
        process=transport_process,
        release=release,
        stock_end=stock_end,
        stock_change=-release,
        notes=notes,
        transport=transport_process,
        start_year=yr,
        end_year=yr,
    )

def calculate_stage_e2(stage_d: StageRecord, c: ModelConstants = C) -> StageRecord:
    return _calculate_stage_biochar(
        "E2",
        stage_d,
        c.biochar_retention_e2,
        "Hainan transport using remaining product mass + fast pyrolysis with fixed 15% biochar retention.",
        c,
    )


def calculate_stage_e3(stage_d: StageRecord, c: ModelConstants = C) -> StageRecord:
    return _calculate_stage_biochar(
        "E3",
        stage_d,
        c.biochar_retention_e3,
        "Hainan transport using remaining product mass + carbon storage maximisation via 70% biochar retention.",
        c,
    )


D_STAGE_FUNCS = {
    "D1": calculate_stage_d1,
    "D2": calculate_stage_d2,
    "D3": calculate_stage_d3,
}

E_STAGE_FUNCS = {"E1": calculate_stage_e1, "E2": calculate_stage_e2, "E3": calculate_stage_e3}

# =========================================================
# BLOCK 5 — PATHWAY EXECUTION
# =========================================================

def carry_stock_through_stage(raw_stage: StageRecord, retained_stock: float) -> StageRecord:
    return raw_stage.copy_with(
        biogenic_release_kgco2e=0.0,
        retained_stock_kgco2e=retained_stock,
        stock_change_kgco2e=0.0,
    )


def _run_stage(
    stage_map: Dict[str, Callable],
    stage_code: Optional[str],
    *,
    err_label: str,
    pathway_code: str,
    args: Tuple[Any, ...],
) -> StageRecord:
    if stage_code is None:
        raise ValueError(f"Pathway '{pathway_code}' requires a {err_label} stage but received None.")
    try:
        return stage_map[stage_code](*args)
    except KeyError as e:
        raise ValueError(f"Unsupported {err_label}_stage '{stage_code}' for pathway '{pathway_code}'.") from e


def run_pathway(pathway_code: str, c: ModelConstants = C) -> PathwayResult:
    meta = get_pathway_meta(pathway_code)

    a = calculate_stage_a(c)
    b = carry_stock_through_stage(calculate_stage_b(meta["b_stage"], c), a.retained_stock_kgco2e)

    stages = [a, b]

    if meta["use_stage_c"]:
        c_stage = calculate_stage_c(a, c)
        stages.append(c_stage)

        if meta["end_stage"] == "C1":
            stages.append(calculate_stage_c1(a, c_stage, c))
        else:
            d = _run_stage(
                D_STAGE_FUNCS,
                meta["d_stage"],
                err_label="d",
                pathway_code=pathway_code,
                args=(c_stage, c)
            )
            e = _run_stage(
                E_STAGE_FUNCS,
                meta["end_stage"],
                err_label="end",
                pathway_code=pathway_code,
                args=(d, c),
            )
            stages += [d, e]
    else:
        d = _run_stage(
            D_STAGE_FUNCS,
            meta["d_stage"],
            err_label="d",
            pathway_code=pathway_code,
            args=(a, c),
        )
        e = _run_stage(
            E_STAGE_FUNCS,
            meta["end_stage"],
            err_label="end",
            pathway_code=pathway_code,
            args=(d, c),
        )
        stages += [d, e]

    return PathwayResult(
        pathway_code=pathway_code,
        pathway_label=meta["label"],
        stage_records=stages,
        description=meta["description"],
    )

def run_all_pathways(c: ModelConstants = C, pathway_codes: Optional[List[str]] = None) -> Dict[str, PathwayResult]:
    return {code: run_pathway(code, c) for code in (pathway_codes or PATHWAY_ORDER)}


def run_group(group: str, c: ModelConstants = C) -> Dict[str, PathwayResult]:
    return run_all_pathways(c, get_group_codes(group))


def rerun_pathway(pathway_code: str, c: ModelConstants = C, **updates: Any) -> PathwayResult:
    return run_pathway(pathway_code, clone_constants(c, **updates))


def rerun_all(c: ModelConstants = C, pathway_codes: Optional[List[str]] = None, **updates: Any) -> Dict[str, PathwayResult]:
    return run_all_pathways(clone_constants(c, **updates), pathway_codes)

