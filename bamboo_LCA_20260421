def main(
    constants: ModelConstants = C,
    horizon_years: float = DEFAULT_TIME_HORIZON_YEARS,
    delta: float = DEFAULT_SENSITIVITY_DELTA,
    show_plots: bool = True,
) -> Dict[str, Any]:
    results, outputs = build_model_outputs(
        constants=constants,
        horizon_years=horizon_years,
        delta=delta,
    )

    if PRINT_SUMMARY_TABLES:
        print_core_outputs(outputs)

    if EXPORT_RESULTS:
        export_outputs(outputs)

    feasibility_data = build_feasibility_matrix(constants)

    if EXPORT_RESULTS:
        feasibility_data.to_csv(TABLE_DIR / "feasibility_matrix.csv", index=False)

    economic_results = compare_e2_e3_economics(results, constants=constants)

    if PRINT_SUMMARY_TABLES:
        print_section_title("ECONOMIC COMPARISON: E2 vs E3")
        for key, df in economic_results.items():
            print(f"\n--- {key} ---")
            print(df.to_string())

    if EXPORT_RESULTS:
        for key, df in economic_results.items():
            export_table(df, f"{key}.csv")

    if GENERATE_PLOTS:
        evaluated_max_decarb = evaluate_max_decarb_parameters(constants)
        max_decarb_sensitivity_results = {
            name: payload["sweep_df"]
            for name, payload in evaluated_max_decarb.items()
        }
        max_decarb_tornado_df = build_max_decarb_tornado_data(
            constants,
            evaluated=evaluated_max_decarb,
        )

        generate_figures(
            outputs,
            show=show_plots,
            max_decarb_sensitivity_results=max_decarb_sensitivity_results,
            max_decarb_tornado_df=max_decarb_tornado_df,
            constants=constants,
        )

    return {
        "constants": constants,
        "results": results,
        "outputs": outputs,
        "feasibility_matrix": feasibility_data,
        "economic_results": economic_results,
        "chart_specs": CHART_SPECS,
        "chart_title_map": get_chart_title_map(),
    }


if __name__ == "__main__":
    main()

