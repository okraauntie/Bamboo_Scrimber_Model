def print_core_outputs(outputs: Dict[str, pd.DataFrame]) -> None:
    for title, key in (
        ("SUMMARY TABLE", "summary"),
        ("TEMPORAL STORAGE SUMMARY", "temporal_summary"),
        ("SENSITIVITY RESULTS", "sensitivity"),
        ("UNCERTAINTY ENVELOPE", "uncertainty"),
        ("BASELINE VS MAXIMUM DECARBONIZATION", "baseline_vs_max_difference"),
    ):
        df = outputs.get(key, pd.DataFrame())
        if df is None or df.empty:
            continue

        if key == "baseline_vs_max_difference":
            df = df.copy()
            df["metric"] = df["metric"].str.replace("Δ", "", regex=False)

            numeric_cols = df.select_dtypes(include="number").columns
            df[numeric_cols] = df[numeric_cols].round(3)

            df = df.rename(columns={
                "baseline": "Baseline",
                "max_decarb": "Maximum Decarbonization",
                "difference": "Max − Baseline",
            })

        print_section_title(title)
        print(df.to_string(index=False))


