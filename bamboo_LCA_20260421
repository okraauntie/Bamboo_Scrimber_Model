def plot_phase_2_net_balance(
    summary_df: pd.DataFrame,
    *,
    title: str,
    show: bool = True,
    filename: str = "phase_2_net_balance.png",
) -> Optional[Path]:
    df = summary_df.copy()
    df = df[df["pathway_code"].isin([
        "A-B1-D2-E1",
        "A-B2-D2-E2",
        "A-B2-D3-E2",
        "A-B3-D3-E2",
        "A-B3-D3-E3",
    ])]

    if df.empty:
        return None

    labels = df["pathway_label"].tolist()
    values = df["net_carbon_balance_kgco2e"].to_numpy()
    colors = ["#d62728" if v < 0 else "#4c72b0" for v in values]

    fig, ax = plt.subplots()
    y = np.arange(len(labels))

    bars = ax.barh(y, values, color=colors)
    xmin = values.min()
    xmax = values.max()
