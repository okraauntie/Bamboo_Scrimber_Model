def _build_sensitivity_outputs(constants: ModelConstants, delta: float) -> Dict[str, pd.DataFrame]:
    baseline_result = _baseline_sensitivity_result(constants)
    baseline_ncb = baseline_result.net_carbon_balance_kgco2e

    rows = []
    for parameter, base, run in _sensitivity_runs(constants):
        if parameter == "Biochar fraction":
            low_value = 0.0
            high_value = delta * constants.biochar_retention_e3 * constants.d2_retention_at_year_25
        else:
            low_value = base * (1.0 - delta)
            high_value = base * (1.0 + delta)

        low, high = run(low_value), run(high_value)
        rows.append({
            "parameter": parameter,
            "baseline_value": base,
            "low_case_value": low_value,
            "high_case_value": high_value,
            "low_ncb_kgco2e": low.net_carbon_balance_kgco2e,
            "high_ncb_kgco2e": high.net_carbon_balance_kgco2e,
            "low_delta_kgco2e": low.net_carbon_balance_kgco2e - baseline_ncb,
            "high_delta_kgco2e": high.net_carbon_balance_kgco2e - baseline_ncb,
            "impact": max(abs(low.net_carbon_balance_kgco2e - baseline_ncb), abs(high.net_carbon_balance_kgco2e - baseline_ncb)),
        })

    sensitivity = reorder_columns(
        pd.DataFrame(rows).sort_values("impact", ascending=False).reset_index(drop=True).assign(rank=lambda x: range(1, len(x) + 1)),
        SENSITIVITY_COLS,
    )
    tornado = reorder_columns(
        sensitivity.assign(
            parameter_label=lambda x: x["parameter"],
            min_delta_kgco2e=lambda x: x[["low_delta_kgco2e", "high_delta_kgco2e"]].min(axis=1),
            max_delta_kgco2e=lambda x: x[["low_delta_kgco2e", "high_delta_kgco2e"]].max(axis=1),
            absolute_swing_kgco2e=lambda x: x[["low_delta_kgco2e", "high_delta_kgco2e"]].abs().max(axis=1),
        ),
        TORNADO_COLS,
    )
    return {"sensitivity": sensitivity, "tornado": tornado}


def biochar_tipping_point_analysis(
    results: Dict[str, PathwayResult],
    constants: ModelConstants = C,
) -> Dict[str, Any]:
    """Analyze how biochar retention fraction affects net carbon balance."""
    
    # Get the Maximum Decarbonization pathway result (or any pathway with E3)
    base_result = results[ASPIRATIONAL_PATHWAY_CODE]
    
    # Get the D3 stage stock (entering E3)
    d3_stage = base_result.get_stage("D3")
    if d3_stage is None:
        raise ValueError("Pathway does not contain D3 stage")
    
    entering_stock = d3_stage.retained_stock_kgco2e
    
    # Get process emissions (including end-of-life transport emissions in E2/E3)
    process_emissions = base_result.total_process_emissions_kgco2e
    
    # Initial biogenic stock
    initial_stock = base_result.initial_biogenic_stock_kgco2e
    
    # Calculate NCB for different biochar retention fractions
    retention_fractions = np.linspace(0, 1, 21)  # 0%, 5%, 10%, ..., 100%
    results_list = []
    
    for retention in retention_fractions:
        # Final retained stock = entering E3 stock × biochar retention
        final_retained = entering_stock * retention
        
        # Biogenic release = initial stock - final retained
        biogenic_release = initial_stock - final_retained
        
        # Net carbon balance
        ncb = initial_stock - process_emissions - biogenic_release
        
        # Also calculate if it's a net sink (NCB > 0)
        is_sink = ncb > 0
        
        results_list.append({
            "biochar_retention_fraction": retention,
            "final_retained_stock_kgco2e": final_retained,
            "biogenic_release_kgco2e": biogenic_release,
            "net_carbon_balance_kgco2e": ncb,
            "is_carbon_sink": is_sink,
            "process_emissions_kgco2e": process_emissions,
            "initial_stock_kgco2e": initial_stock,
        })
    
    df = pd.DataFrame(results_list)
    
    # Find the tipping point with interpolation for accuracy
    tipping_point = None
    for i in range(len(df) - 1):
        ncb1 = df["net_carbon_balance_kgco2e"].iloc[i]
        ncb2 = df["net_carbon_balance_kgco2e"].iloc[i + 1]
        if ncb1 <= 0 <= ncb2:
            # Linear interpolation
            r1 = df["biochar_retention_fraction"].iloc[i]
            r2 = df["biochar_retention_fraction"].iloc[i + 1]
            tipping_point = r1 + (0 - ncb1) * (r2 - r1) / (ncb2 - ncb1)
            break
    
    return {
        "biochar_tipping_analysis": df,
        "tipping_point_fraction": tipping_point,
        "tipping_point_percent": tipping_point * 100 if tipping_point else None,
    }

def build_baseline_to_max_waterfall_df(
    results: Dict[str, PathwayResult],
) -> pd.DataFrame:
    """
    Build a waterfall decomposition from baseline A-B1-D2-E1
    to maximum decarbonization A-B3-D3-E3 using incremental
    parameter amendments.
    """

    baseline = results["A-B1-D2-E1"]
    step_1 = results["A-B2-D2-E1"]
    step_2 = results["A-B3-D2-E1"]
    step_3 = results["A-B3-D3-E1"]
    step_4 = results["A-B3-D3-E2"]
    final = results["A-B3-D3-E3"]

    rows = [
        {
            "step": "Baseline",
            "pathway_code": "A-B1-D2-E1",
            "ncb": baseline.net_carbon_balance_kgco2e,
            "delta": baseline.net_carbon_balance_kgco2e,
            "bar_type": "absolute",
        },
        {
            "step": "Limited manufacturing improvement\n(B1 → B2)",
            "pathway_code": "A-B2-D2-E1",
            "ncb": step_1.net_carbon_balance_kgco2e,
            "delta": step_1.net_carbon_balance_kgco2e - baseline.net_carbon_balance_kgco2e,
            "bar_type": "delta",
        },
        {
            "step": "Maximum manufacturing improvement\n(B2 → B3)",
            "pathway_code": "A-B3-D2-E1",
            "ncb": step_2.net_carbon_balance_kgco2e,
            "delta": step_2.net_carbon_balance_kgco2e - step_1.net_carbon_balance_kgco2e,
            "bar_type": "delta",
        },
        {
            "step": "Service life / retention improvement\n(D2 → D3)",
            "pathway_code": "A-B3-D3-E1",
            "ncb": step_3.net_carbon_balance_kgco2e,
            "delta": step_3.net_carbon_balance_kgco2e - step_2.net_carbon_balance_kgco2e,
            "bar_type": "delta",
        },
        {
            "step": "Limited end-of-life improvement\n(E1 → E2)",
            "pathway_code": "A-B3-D3-E2",
            "ncb": step_4.net_carbon_balance_kgco2e,
            "delta": step_4.net_carbon_balance_kgco2e - step_3.net_carbon_balance_kgco2e,
            "bar_type": "delta",
        },
        {
            "step": "Maximum end-of-life improvement\n(E2 → E3)",
            "pathway_code": "A-B3-D3-E3",
            "ncb": final.net_carbon_balance_kgco2e,
            "delta": final.net_carbon_balance_kgco2e - step_4.net_carbon_balance_kgco2e,
            "bar_type": "delta",
        },
        {
            "step": "Final: Maximum Decarbonization",
            "pathway_code": "A-B3-D3-E3",
            "ncb": final.net_carbon_balance_kgco2e,
            "delta": final.net_carbon_balance_kgco2e,
            "bar_type": "absolute",
        },
    ]

    return pd.DataFrame(rows)

def build_baseline_vs_max_difference_table(
    results: Dict[str, PathwayResult],
    baseline_code: str = "A-B1-D2-E1",
    max_code: str = "A-B3-D3-E3",
    round_digits: int = 3,
) -> pd.DataFrame:
    """
    Build a comparison table quantifying differences between baseline and
    maximum decarbonization pathways.

    Outputs:
    - Difference in net carbon balance
    - Difference in process emissions
    - Difference in biogenic release
    - Difference in retained stock
    """

    baseline = results[baseline_code]
    max_case = results[max_code]

    ncb_baseline = baseline.net_carbon_balance_kgco2e
    ncb_max = max_case.net_carbon_balance_kgco2e

    process_baseline = baseline.total_process_emissions_kgco2e
    process_max = max_case.total_process_emissions_kgco2e

    release_baseline = baseline.total_biogenic_release_kgco2e
    release_max = max_case.total_biogenic_release_kgco2e

    retained_baseline = baseline.final_retained_stock_kgco2e
    retained_max = max_case.final_retained_stock_kgco2e

    diff_ncb = ncb_max - ncb_baseline
    diff_process = process_baseline - process_max
    diff_release = release_baseline - release_max
    diff_retained = retained_max - retained_baseline

    return pd.DataFrame([
        {
            "metric": "Net carbon balance (NCB)",
            "baseline": round(ncb_baseline, round_digits),
            "max_decarb": round(ncb_max, round_digits),
            "difference": round(diff_ncb, round_digits),
        },
        {
            "metric": "Process emissions",
            "baseline": round(process_baseline, round_digits),
            "max_decarb": round(process_max, round_digits),
            "difference": round(diff_process, round_digits),
        },
        {
            "metric": "Biogenic release",
            "baseline": round(release_baseline, round_digits),
            "max_decarb": round(release_max, round_digits),
            "difference": round(diff_release, round_digits),
        },
        {
            "metric": "Retained stock",
            "baseline": round(retained_baseline, round_digits),
            "max_decarb": round(retained_max, round_digits),
            "difference": round(diff_retained, round_digits),
        },
    ])


def _build_uncertainty_outputs(
    results: Dict[str, PathwayResult],
    constants: ModelConstants,
    delta: float,
    temporal_summary: pd.DataFrame,
) -> Dict[str, pd.DataFrame]:
    baseline_ncb = _baseline_sensitivity_result(constants).net_carbon_balance_kgco2e
    worst = _baseline_sensitivity_result(
        constants,
        electricity_ef=constants.electricity_kgco2e_per_kwh * (1 + delta),
        resin_fraction=constants.resin_fraction * (1 + delta),
        manufacturing_energy_multiplier=1 + delta,
        transport_emissions_multiplier=1 + delta,
        retention_at_year_25=constants.d2_retention_at_year_25 * (1 - delta),
        biochar_fraction=0.0,
    ).net_carbon_balance_kgco2e
    best = _baseline_sensitivity_result(
        constants,
        electricity_ef=constants.electricity_kgco2e_per_kwh * (1 - delta),
        resin_fraction=constants.resin_fraction * (1 - delta),
        manufacturing_energy_multiplier=1 - delta,
        transport_emissions_multiplier=1 - delta,
        retention_at_year_25=constants.d2_retention_at_year_25 * (1 + delta),
        biochar_fraction=delta * constants.biochar_retention_e3 * constants.d2_retention_at_year_25,
    ).net_carbon_balance_kgco2e

    uncertainty = reorder_columns(pd.DataFrame([
        {"scenario_group": "Combined uncertainty envelope", "scenario": "Baseline", "pathway": BASELINE_PATHWAY_CODE, "net_carbon_balance_kgco2e": baseline_ncb, "delta_vs_baseline_kgco2e": 0.0},
        {"scenario_group": "Combined uncertainty envelope", "scenario": "Combined worst-case", "pathway": BASELINE_PATHWAY_CODE, "net_carbon_balance_kgco2e": worst, "delta_vs_baseline_kgco2e": worst - baseline_ncb},
        {"scenario_group": "Combined uncertainty envelope", "scenario": "Combined best-case", "pathway": BASELINE_PATHWAY_CODE, "net_carbon_balance_kgco2e": best, "delta_vs_baseline_kgco2e": best - baseline_ncb},
    ]).round(4), UNCERTAINTY_COLS)

    aspirational = reorder_columns(pd.DataFrame([
        {"scenario_group": "Pathway comparison", "scenario": "Baseline", "pathway": BASELINE_PATHWAY_CODE, "net_carbon_balance_kgco2e": results[BASELINE_PATHWAY_CODE].net_carbon_balance_kgco2e, "delta_vs_baseline_kgco2e": 0.0},
        {"scenario_group": "Pathway comparison", "scenario": "Aspirational best-case pathway", "pathway": ASPIRATIONAL_PATHWAY_CODE, "net_carbon_balance_kgco2e": results[ASPIRATIONAL_PATHWAY_CODE].net_carbon_balance_kgco2e, "delta_vs_baseline_kgco2e": results[ASPIRATIONAL_PATHWAY_CODE].net_carbon_balance_kgco2e - results[BASELINE_PATHWAY_CODE].net_carbon_balance_kgco2e},
    ]).round(4), UNCERTAINTY_COLS)

    combined_uncertainty = pd.concat([uncertainty, aspirational], ignore_index=True)
    combined_uncertainty["interpretation_label"] = combined_uncertainty["net_carbon_balance_kgco2e"].map(
        lambda x: "Carbon negative" if x > 0.05 else ("Carbon positive" if x < -0.05 else "Near carbon neutral")
    )

    tipping = _group_summary(results, "phase_2")[["pathway_code", "pathway_label", "net_carbon_balance_kgco2e"]].merge(
        temporal_summary[["pathway_code", "temporal_storage_benefit_tco2e_year", "average_retained_stock_tco2e"]],
        on="pathway_code",
        how="left",
    ).rename(columns={"pathway_code": "pathway", "pathway_label": "scenario", "net_carbon_balance_kgco2e": "NCB_relocation"})
    assert_unique_columns(tipping, "tipping")
    tipping = reorder_columns(
        tipping.assign(carbon_negative=lambda x: x["NCB_relocation"] > 0).sort_values("NCB_relocation", ascending=False).reset_index(drop=True).assign(rank=lambda x: range(1, len(x) + 1)),
        TIPPING_POINT_COLS,
    )

    return {
        "uncertainty": uncertainty,
        "aspirational_best_case": aspirational,
        "combined_uncertainty": combined_uncertainty,
        "tipping": tipping,
    }


def build_outputs(
    results: Dict[str, PathwayResult],
    constants: ModelConstants = C,
    horizon_years: float = DEFAULT_TIME_HORIZON_YEARS,
    delta: float = DEFAULT_SENSITIVITY_DELTA,
) -> Dict[str, pd.DataFrame]:
    reporting = _build_reporting_outputs(results)
    temporal = _build_temporal_outputs(results, horizon_years)
    sensitivity = _build_sensitivity_outputs(constants, delta)
    uncertainty = _build_uncertainty_outputs(results, constants, delta, temporal["temporal_summary"])
    tipping_analysis = biochar_tipping_point_analysis(results, constants)
    baseline_vs_max_difference = build_baseline_vs_max_difference_table(results)
    baseline_to_max_waterfall = build_baseline_to_max_waterfall_df(results)
    
    return {
        **reporting,
        **temporal,
        **sensitivity,
        **uncertainty,
        **tipping_analysis,
        "baseline_vs_max_difference": baseline_vs_max_difference,
        "baseline_to_max_waterfall": baseline_to_max_waterfall
    }


def max_decarb_sensitivity_runs(
    constants: ModelConstants = C
) -> List[Tuple[str, float, float, float, Callable[[float], PathwayResult]]]:
    """
    Define sensitivity parameters for Maximum Decarbonization pathway.
    Returns: (parameter_name, min_value, baseline_value, max_value, function_to_run)
    """
    sensitivity_params = []

    for spec in _get_max_decarb_parameter_specs(constants):
        sensitivity_params.append((
            spec["name"],
            spec["min"],
            spec["base"],
            spec["max"],
            lambda v, p=spec["param"]: run_pathway(
                ASPIRATIONAL_PATHWAY_CODE,
                _apply_max_decarb_parameter(constants, p, v),
            ),
        ))

    return sensitivity_params

def run_max_decarb_sensitivity_analysis(
    constants: ModelConstants = C, 
    n_points: int = 20
) -> Dict[str, pd.DataFrame]:
    """
    Return sweep dataframes for each maximum-decarbonization parameter
    """
    evaluated = evaluate_max_decarb_parameters(constants, n_points=n_points)
    return {name: payload["sweep_df"] for name, payload in evaluated.items()}
    

def build_max_decarb_tornado_data(
    constants: ModelConstants = C,
    evaluated: Optional[Dict[str, Dict[str, Any]]] = None,
) -> pd.DataFrame:
    """
    Build tornado input data for the Maximum Decarbonization pathway
    from shared parameter evaluations.
    """
    if evaluated is None:
        evaluated = evaluate_max_decarb_parameters(constants)

    rows = []

    for param_name, payload in evaluated.items():
        spec = payload["spec"]
        min_result = payload["min_result"]
        max_result = payload["max_result"]
        base_ncb = payload["base_ncb"]

        min_val = spec["min"]
        base_val = spec["base"]
        max_val = spec["max"]
        lower_is_better = spec["lower_is_better"]

        min_ncb = min_result.net_carbon_balance_kgco2e
        max_ncb = max_result.net_carbon_balance_kgco2e

        min_delta = min_ncb - base_ncb
        max_delta = max_ncb - base_ncb

        if lower_is_better:
            better_delta = min_delta
            worse_delta = max_delta
            better_label = f"Min: {min_val:.3f}"
            worse_label = f"Max: {max_val:.3f}"
        else:
            better_delta = max_delta
            worse_delta = min_delta
            better_label = f"Max: {max_val:.3f}"
            worse_label = f"Min: {min_val:.3f}"

        rows.append({
            "parameter": param_name,
            "param": spec["param"],
            "base_ncb": base_ncb,
            "base_val": base_val,
            "min_val": min_val,
            "max_val": max_val,
            "min_ncb": min_ncb,
            "max_ncb": max_ncb,
            "min_delta": min_delta,
            "max_delta": max_delta,
            "better_delta": better_delta,
            "worse_delta": worse_delta,
            "better_label": better_label,
            "worse_label": worse_label,
            "impact": abs(worse_delta) + abs(better_delta),
            "lower_is_better": lower_is_better,
            "note": spec.get("note", ""),
        })

    return pd.DataFrame(rows).sort_values("impact", ascending=True).reset_index(drop=True)


def evaluate_max_decarb_parameters(
    constants: ModelConstants = C,
    n_points: int = 20,
) -> Dict[str, Dict[str, Any]]:
    """
    Evaluate all max-decarbonization parameters once and return both:
    - sweep data across the full range
    - min/base/max endpoint results for tornado-style summaries
    """
    out: Dict[str, Dict[str, Any]] = {}

    base_result = run_pathway(ASPIRATIONAL_PATHWAY_CODE, constants)
    base_ncb = base_result.net_carbon_balance_kgco2e

    for spec in _get_max_decarb_parameter_specs(constants):
        param_name = spec["name"]
        param_key = spec["param"]
        min_val = spec["min"]
        base_val = spec["base"]
        max_val = spec["max"]

        # Endpoint runs
        min_constants = _apply_max_decarb_parameter(constants, param_key, min_val)
        max_constants = _apply_max_decarb_parameter(constants, param_key, max_val)

        min_result = run_pathway(ASPIRATIONAL_PATHWAY_CODE, min_constants)
        max_result = run_pathway(ASPIRATIONAL_PATHWAY_CODE, max_constants)

        # Sweep runs
        sweep_rows = []
        for val in np.linspace(min_val, max_val, n_points):
            result = run_pathway(
                ASPIRATIONAL_PATHWAY_CODE,
                _apply_max_decarb_parameter(constants, param_key, float(val)),
            )
            sweep_rows.append({
                "parameter_value": float(val),
                "net_carbon_balance": result.net_carbon_balance_kgco2e,
                "final_retained_stock": result.final_retained_stock_kgco2e,
                "process_emissions": result.total_process_emissions_kgco2e,
                "biogenic_release": result.total_biogenic_release_kgco2e,
                "is_carbon_sink": result.net_carbon_balance_kgco2e > 0,
            })

        out[param_name] = {
            "spec": spec,
            "base_ncb": base_ncb,
            "min_result": min_result,
            "max_result": max_result,
            "sweep_df": pd.DataFrame(sweep_rows),
        }

    return out



