def _bar(
    labels: List[str],
    values: np.ndarray,
    *,
    title: str,
    xlabel: str,
    ylabel: str,
    rotation: int = 0,
    ha: str = "center",
    filename: Optional[str] = None,
    show: bool = True,
    horizontal: bool = False,
) -> Optional[Path]:
    if not labels:
        return None

    fig, ax = plt.subplots()
    x = np.arange(len(labels))

    if horizontal:
        ax.barh(x, values)
        ax.set_yticks(x)
        ax.set_yticklabels(labels)
        ax.set_xlabel(xlabel)
        ax.set_ylabel(ylabel)
        ax.set_title(title)
        ax.axvline(0, linewidth=0.8)
    else:
        ax.bar(x, values)
        ax.set_xlabel(xlabel)
        ax.set_ylabel(ylabel)
        ax.set_title(title)
        ax.set_xticks(x)
        ax.set_xticklabels(labels, rotation=rotation, ha=ha)
        ax.axhline(0, linewidth=0.8)

    return _finish_plot(fig, filename, show)


def _grouped(
    labels: List[str],
    series: List[Tuple[str, np.ndarray]],
    *,
    title: str,
    xlabel: str,
    ylabel: str,
    width: float = 0.18,
    rotation: int = 0,
    ha: str = "center",
    filename: Optional[str] = None,
    show: bool = True,
    colors: Optional[Dict[str, str]] = None,
) -> Optional[Path]:
    if not labels or not series:
        return None

    fig, ax = plt.subplots()
    x = np.arange(len(labels))
    offsets = np.linspace(-(len(series) - 1) / 2, (len(series) - 1) / 2, len(series)) * width

    for off, (name, vals) in zip(offsets, series):
        ax.bar(x + off, vals, width=width, label=name, color=(colors.get(name) if colors else None))

    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    ax.set_xticks(x)
    ax.set_xticklabels(labels, rotation=rotation, ha=ha)
    ax.axhline(0, linewidth=0.8)
    ax.legend(fontsize=ANNOTATION_FONT_SIZE, loc="lower center", bbox_to_anchor=(0.5, 1.10), ncol=2)

    return _finish_plot(fig, filename, show)


def _tornado(
    df: pd.DataFrame,
    *,
    title: str,
    filename: Optional[str] = None,
    show: bool = True,
) -> Optional[Path]:
    if df.empty:
        return None

    d = df.sort_values("absolute_swing_kgco2e").reset_index(drop=True)
    left = np.minimum(d["min_delta_kgco2e"].to_numpy(), d["max_delta_kgco2e"].to_numpy())
    width = np.abs(d["max_delta_kgco2e"].to_numpy() - d["min_delta_kgco2e"].to_numpy())

    fig, ax = plt.subplots()
    y = np.arange(len(d))
    ax.barh(y, width, left=left)
    ax.set_yticks(y)
    ax.set_yticklabels(d["parameter_label"].tolist())
    ax.set_xlabel("Change in net carbon balance (kgCO2e)")
    ax.set_title(title)
    ax.axvline(0, linewidth=0.8)

    return _finish_plot(fig, filename, show)


def _phase_1_summary(
    df: pd.DataFrame,
    *,
    title: str,
    filename: Optional[str] = None,
    show: bool = True,
) -> Optional[Path]:
    if df.empty:
        return None

    d = df.copy()
    d["scenario"] = pd.Categorical(
        d["scenario"],
        categories=["Japan disposal", "Relocation"],
        ordered=True,
    )
    d = d.sort_values("scenario").reset_index(drop=True)

    labels = d["scenario"].tolist()
    process = d["total_process_emissions_kgco2e"].to_numpy()
    biogenic = d["total_biogenic_release_kgco2e"].to_numpy()
    net = d["net_carbon_balance_kgco2e"].to_numpy()

    fig, ax = plt.subplots()
    x = np.arange(len(labels))
    width = 0.22

    b1 = ax.bar(x - width, process, width=width, label="Process emissions")
    b2 = ax.bar(x, biogenic, width=width, label="Biogenic release")
    b3 = ax.bar(x + width, net, width=width, label="Net carbon balance")

    ax.set_xlabel("Scenario")
    ax.set_ylabel("kg CO2e per kg bamboo scrimber")
    ax.set_title(title)
    ax.set_xticks(x)
    ax.set_xticklabels(labels)
    ax.axhline(0, linewidth=0.8)
    ax.legend(fontsize=ANNOTATION_FONT_SIZE)
    ax.set_ylim(min(net) - 0.15, max(biogenic) + 0.25)

    for bars in (b1, b2, b3):
        for bar in bars:
            h = bar.get_height()
            ax.text(
                bar.get_x() + bar.get_width() / 2,
                h + (0.02 if h >= 0 else -0.04),
                f"{h:.3f}",
                ha="center",
                va="bottom" if h >= 0 else "top",
                fontsize=ANNOTATION_FONT_SIZE,
            )

    if len(process) == 2:
        delta = process[1] - process[0]
        y = max(process) + 0.10
        ax.plot([x[0] - width, x[1] - width], [y, y], linewidth=1.0)
        ax.text(
            np.mean([x[0] - width, x[1] - width]),
            y + 0.015,
            f"Relocation adds {delta:.3f} kg CO2e process emissions",
            ha="center",
            va="bottom",
            fontsize=ANNOTATION_FONT_SIZE,
        )

    return _finish_plot(fig, filename, show)


def plot_biochar_tipping_point(
    df: pd.DataFrame,
    tipping_point: Optional[float],
    *,
    title: str,
    filename: Optional[str] = None,
    show: bool = True,
) -> Optional[Path]:
    fig, ax = plt.subplots()

    retention = df["biochar_retention_fraction"].to_numpy()
    ncb = df["net_carbon_balance_kgco2e"].to_numpy()

    ax.plot(retention * 100, ncb, "b-", linewidth=2, label="Net carbon balance")
    ax.axhline(0, color="red", linestyle="--", linewidth=1, label="Carbon neutral (source/sink boundary)")

    if tipping_point is not None:
        ax.axvline(
            tipping_point * 100,
            color="green",
            linestyle=":",
            linewidth=2,
            label=f"Tipping point: {tipping_point * 100:.1f}% retention",
        )
        ax.annotate(
            f"Carbon sink above {tipping_point * 100:.1f}%",
            xy=(tipping_point * 100, 0),
            xytext=(tipping_point * 100 + 10, 0.2),
            arrowprops=dict(arrowstyle="->", color="green"),
            fontsize=ANNOTATION_FONT_SIZE,
        )

    ax.fill_between(retention * 100, 0, ncb, where=(ncb >= 0), color="green", alpha=0.3, label="Carbon sink (net storage)")
    ax.fill_between(retention * 100, 0, ncb, where=(ncb < 0), color="red", alpha=0.3, label="Carbon source (net emission)")

    ax.set_xlabel("Biochar retention fraction (%)")
    ax.set_ylabel("Net carbon balance (kg CO2e per functional unit)")
    ax.set_title(title)
    ax.legend(loc="best", fontsize=ANNOTATION_FONT_SIZE)
    ax.grid(True, alpha=0.3)

    return _finish_plot(fig, filename, show)


def plot_max_decarb_sensitivity_chart(
    constants: ModelConstants = C,
    sensitivity_results: Optional[Dict[str, pd.DataFrame]] = None,
    *,
    title: str,
    show: bool = True,
    filename: str = "max_decarb_sensitivity.png",
) -> Optional[Path]:
    if sensitivity_results is None:
        sensitivity_results = run_max_decarb_sensitivity_analysis(constants)

    parameter_specs = _get_max_decarb_parameter_specs(constants)
    base_result = run_pathway(ASPIRATIONAL_PATHWAY_CODE, constants)
    base_ncb = base_result.net_carbon_balance_kgco2e

    n_params = len(parameter_specs)
    n_cols = 2
    n_rows = (n_params + n_cols - 1) // n_cols

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(10.5, 3.8 * n_rows))
    axes = axes.flatten() if n_params > 1 else [axes]

    for idx, param_info in enumerate(parameter_specs):
        ax = axes[idx]
        param_name = param_info["name"]
        baseline_x = param_info["base"]

        df = sensitivity_results.get(param_name, pd.DataFrame())
        if df.empty:
            ax.set_visible(False)
            continue

        values = df["parameter_value"].to_numpy()
        ncb_array = df["net_carbon_balance"].to_numpy()

        ax.plot(values, ncb_array, "b-", linewidth=2, marker="o", markersize=3)
        ax.axhline(base_ncb, color="gray", linestyle="--", linewidth=1, alpha=0.7, label=f"Base: {base_ncb:.3f}")
        ax.axhline(0, color="green", linestyle=":", linewidth=1, alpha=0.7, label="Carbon neutral")

        baseline_idx = np.argmin(np.abs(values - baseline_x))
        ax.plot(values[baseline_idx], ncb_array[baseline_idx], "ro", markersize=6, label=f"Baseline: {baseline_x:.3f}")

        ax.fill_between(values, 0, ncb_array, where=(ncb_array >= 0), color="green", alpha=0.2)
        ax.fill_between(values, 0, ncb_array, where=(ncb_array < 0), color="red", alpha=0.2)

        for i in range(len(ncb_array) - 1):
            if ncb_array[i] <= 0 <= ncb_array[i + 1] or ncb_array[i] >= 0 >= ncb_array[i + 1]:
                v1, v2 = values[i], values[i + 1]
                n1, n2 = ncb_array[i], ncb_array[i + 1]
                if n2 != n1:
                    crossing = v1 + (0 - n1) * (v2 - v1) / (n2 - n1)
                    ax.axvline(
                        crossing,
                        color="orange",
                        linestyle="--",
                        linewidth=1,
                        alpha=0.7,
                        label=f"Tipping: {crossing:.3f}",
                    )
                break

        ax.set_xlabel(param_name)
        ax.set_ylabel("Net carbon balance (kg CO2e)")
        ax.set_title(param_name)
        ax.legend(loc="best", fontsize=ANNOTATION_FONT_SIZE)
        ax.grid(True, alpha=0.3)

    for idx in range(len(parameter_specs), len(axes)):
        axes[idx].set_visible(False)

    fig.suptitle(
        f"{title}\nBase NCB = {base_ncb:.3f} kg CO2e",
        fontweight="bold",
        fontsize=TITLE_FONT_SIZE
    )

    return _finish_plot(fig, filename, show)


def plot_max_decarb_tornado(
    constants: ModelConstants = C,
    tornado_df: Optional[pd.DataFrame] = None,
    *,
    title: str,
    show: bool = True,
    filename: str = "max_decarb_tornado.png",
) -> Optional[Path]:
    if tornado_df is None:
        tornado_df = build_max_decarb_tornado_data(constants)

    if tornado_df.empty:
        return None

    df = tornado_df.copy()
    base_ncb = df["base_ncb"].iloc[0]

    fig, ax = plt.subplots(figsize=(10.5, 7))
    x_min = -0.65
    x_max = 0.35
    ax.set_xlim(x_min, x_max)
    padding = 0.04

    y_pos = np.arange(len(df))

    for i, (_, row) in enumerate(df.iterrows()):
        worse_width = abs(row["worse_delta"])
        worse_start = min(0, row["worse_delta"])
        if worse_start < x_min:
            worse_start = x_min
        if worse_start + worse_width > 0:
            worse_width = 0 - worse_start

        ax.barh(
            i,
            worse_width,
            left=worse_start,
            color="#cd5c5c",
            alpha=0.85,
            edgecolor="#8b0000",
            linewidth=0.8,
        )

        better_width = abs(row["better_delta"])
        better_start = 0
        if better_start + better_width > x_max:
            better_width = x_max - better_start

        ax.barh(
            i,
            better_width,
            left=better_start,
            color="#4682b4",
            alpha=0.85,
            edgecolor="#00008b",
            linewidth=0.8,
        )

        if row["worse_delta"] != 0 and row["worse_delta"] > x_min + 0.05:
            label_x = max(x_min + padding, row["worse_delta"] - 0.04)
            ax.text(
                label_x,
                i,
                f"{row['worse_delta']:+.3f}",
                ha="right" if row["worse_delta"] < -0.05 else "left",
                va="center",
                fontsize=ANNOTATION_FONT_SIZE,
                color="#8b0000",
                fontweight="bold",
            )
        elif row["worse_delta"] != 0:
            ax.text(
                x_min + padding,
                i,
                f"{row['worse_delta']:+.3f}",
                ha="left",
                va="center",
                fontsize=ANNOTATION_FONT_SIZE,
                color="#8b0000",
            )

        if row["better_delta"] != 0 and row["better_delta"] < x_max - 0.05:
            label_x = min(x_max - padding, row["better_delta"] + 0.04)
            ax.text(
                label_x,
                i,
                f"+{row['better_delta']:.3f}",
                ha="left" if row["better_delta"] > 0.05 else "right",
                va="center",
                fontsize=ANNOTATION_FONT_SIZE,
                color="#00008b",
                fontweight="bold",
            )
        elif row["better_delta"] != 0:
            ax.text(
                x_max - padding,
                i,
                f"+{row['better_delta']:.3f}",
                ha="right",
                va="center",
                fontsize=ANNOTATION_FONT_SIZE,
                color="#00008b",
            )

        if "grid carbon intensity" in row["parameter"].lower():
            provincial_grid_intensities = {
                "Zhejiang": 0.4974,
                "National avg": 0.6096,
                "Yunnan": 0.1333,
                "Tianjin": 0.6796,
                "Guangdong": 0.4419,
                "Sichuan": 0.1564,
            }

            min_val = row["min_val"]
            max_val = row["max_val"]
            min_delta = row["min_delta"]
            max_delta = row["max_delta"]

            if max_val != min_val:
                left_label_x = x_min + 0.16
                right_label_x = x_max - 0.03

                province_label_positions = {
                    "Zhejiang":     (left_label_x +0.15,  i + 1.10, "right"),
                    "Tianjin":      (left_label_x +0.15,  i - 0.30, "right"),
                    "National avg": (left_label_x +0.15,  i + 0.70, "right"),
                    "Guangdong":    (left_label_x +0.15,  i - 0.80, "right"),
                    "Sichuan":      (right_label_x - 0.02, i - 0.90, "right"),
                    "Yunnan":       (right_label_x, i - 0.60, "right"),
                }

                for province, grid_value in provincial_grid_intensities.items():
                    province_delta = min_delta + (
                        (grid_value - min_val) / (max_val - min_val)
                    ) * (max_delta - min_delta)

                    ax.plot(
                        province_delta,
                        i,
                        "o",
                        markersize=7,
                        markeredgecolor="black",
                        markeredgewidth=0.8,
                        zorder=15,
                    )

                    x_text, y_text, ha = province_label_positions[province]

                    ax.annotate(
                        f"{province}: {grid_value:.4f}",
                        xy=(province_delta, i),
                        xytext=(x_text, y_text),
                        ha=ha,
                        va="center",
                        fontsize=ANNOTATION_FONT_SIZE,
                        arrowprops=dict(
                            arrowstyle="-",
                            color="black",
                            lw=0.8,
                            alpha=1.0,
                            shrinkA=0,
                            shrinkB=0,
                        ),
                        zorder=20,
                    )

    ax.axvline(0, color="black", linewidth=2, linestyle="-")
    ax.grid(axis="x", alpha=0.25, linestyle="--", linewidth=0.5)
    ax.set_axisbelow(True)

    ax.set_yticks(y_pos)
    ax.set_yticklabels(df["parameter"].tolist())
    ax.tick_params(axis="y", left=True, right=False)

    ax.set_xlabel(
        "Change in net carbon balance (kg CO2e) from base case",
        fontsize=ANNOTATION_FONT_SIZE,
        fontweight="medium",
    )
    ax.xaxis.grid(True, alpha=0.3, linestyle="--")

    ax.set_title(
        f"{title}\nBase NCB = {base_ncb:.3f} kg CO2e",
        fontsize=TITLE_FONT_SIZE,
        fontweight="bold",
        pad=15,
    )

    from matplotlib.patches import Patch

    legend_elements = [
        Patch(facecolor="#cd5c5c", alpha=0.85, edgecolor="#8b0000", label="Worsens NCB"),
        Patch(facecolor="#4682b4", alpha=0.85, edgecolor="#00008b", label="Improves NCB"),
    ]
    ax.legend(
        handles=legend_elements,
        loc="lower right",
        fontsize=ANNOTATION_FONT_SIZE,
        framealpha=1,
        shadow=False,
    )

    return _finish_plot(fig, filename, show)


def plot_baseline_to_max_waterfall(
    df: pd.DataFrame,
    *,
    title: str,
    show: bool = True,
    filename: str = "baseline_to_max_waterfall.png",
) -> Optional[Path]:
    if df.empty:
        return None

    values = df["delta"].to_list()
    labels = df["step"].to_list()
    bar_types = df["bar_type"].to_list()

    bottoms = []
    running = 0.0

    for i, (value, bar_type) in enumerate(zip(values, bar_types)):
        if i == 0 or i == len(values) - 1 or bar_type == "absolute":
            bottoms.append(0.0)
            if i == 0:
                running = df.loc[i, "ncb"]
        else:
            if value >= 0:
                bottoms.append(running)
            else:
                bottoms.append(running + value)
            running += value

    fig, ax = plt.subplots(figsize=(10.5, 7.0))
    x = np.arange(len(labels))

    colors = []
    for i, v in enumerate(values):
        if i == 0 or i == len(values) - 1:
            colors.append("#4c78a8")
        elif v >= 0:
            colors.append("#59a14f")
        else:
            colors.append("#e15759")

    bars = ax.bar(x, values, bottom=bottoms, color=colors)

    running = df.loc[0, "ncb"]
    for i in range(1, len(values) - 1):
        ax.plot([i - 1 + 0.4, i - 0.4], [running, running], color="gray", linewidth=0.8)
        running += values[i]

    bar_tops = [bottom + value for bottom, value in zip(bottoms, values)]
    y_min = min(0.0, min(bottoms), min(bar_tops))
    y_max = max(0.0, max(bottoms), max(bar_tops))

    y_range = y_max - y_min
    top_padding = max(0.08, 0.12 * y_range)
    bottom_padding = max(0.04, 0.04 * y_range)

    ax.set_ylim(y_min - bottom_padding, y_max + top_padding)
    ax.axhline(0, color="black", linewidth=0.8)
    ax.set_xticks(x)
    ax.set_xticklabels(labels, rotation=15, ha="right")
    ax.tick_params(axis="x", pad=8)
    ax.set_ylabel("Net carbon balance (kg CO2e per functional unit)")
    ax.set_title(title)

    for i, bar in enumerate(bars):
        height = values[i]
        y_top = bottoms[i] + height
        label = f"{height:.3f}" if i in [0, len(values) - 1] else f"{height:+.3f}"

        if height >= 0:
            text_y = y_top + 0.03
            va = "bottom"
        else:
            text_y = y_top + 0.06
            va = "bottom"

        ax.text(
            bar.get_x() + bar.get_width() / 2,
            text_y,
            label,
            ha="center",
            va=va,
            fontsize=ANNOTATION_FONT_SIZE,
        )

    plt.subplots_adjust(bottom=0.28)
    return _finish_plot(fig, filename, show, use_tight_layout=False)


