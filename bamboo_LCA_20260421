def plot_chart(
    chart_id: str,
    outputs: Dict[str, pd.DataFrame],
    show: bool = True,
    max_decarb_sensitivity_results: Optional[Dict[str, pd.DataFrame]] = None,
    max_decarb_tornado_df: Optional[pd.DataFrame] = None,
    constants: ModelConstants = C,
) -> Optional[Path]:
    spec = CHART_SPECS[chart_id]
    title, filename = spec["title"], spec["filename"]

    if chart_id == "baseline_stage_contribution":
        return plot_baseline_stage_contribution(outputs["baseline_stage_contribution"], outputs["summary"], title=title, show=show, filename=filename)

    elif chart_id == "tornado":
        return _tornado(outputs["tornado"], title=title, filename=filename, show=show)

    elif chart_id == "phase_1_summary":
        return _phase_1_summary(outputs["phase_1_summary"], title=title, filename=filename, show=show)

    elif chart_id == "phase_1_tonne_year":
        return plot_phase_1_tonne_year(outputs["temporal_summary"], title=title, show=show, filename=filename)

    elif chart_id == "phase_2_stage_breakdown":
        return plot_phase_2_stage_breakdown(outputs["phase_2_stage_split_pivot"], title=title, show=show, filename=filename)

    elif chart_id == "phase_2_net_balance":
        return plot_phase_2_net_balance(outputs["summary"], title=title, show=show, filename=filename)

    elif chart_id == "phase_2_tonne_year":
        return plot_phase_2_tonne_year(outputs["temporal_summary"], title=title, show=show, filename=filename)

    elif chart_id == "biochar_tipping_point":
        tipping_data = outputs.get("biochar_tipping_analysis")
        if tipping_data is None:
            return None
        tipping_point = outputs.get("tipping_point_fraction")
        return plot_biochar_tipping_point(tipping_data, tipping_point, title=title, filename=filename, show=show)

    elif chart_id == "baseline_to_max_waterfall":
        return plot_baseline_to_max_waterfall(df=outputs["baseline_to_max_waterfall"], title=title, show=show, filename=filename)

    elif chart_id == "max_decarb_sensitivity":
        return plot_max_decarb_sensitivity_chart(constants=constants, sensitivity_results=max_decarb_sensitivity_results, title=title, show=show, filename=filename)

    elif chart_id == "max_decarb_tornado":
        return plot_max_decarb_tornado(constants=constants, tornado_df=max_decarb_tornado_df, title=title, show=show, filename=filename)

    elif chart_id == "baseline_vs_max_difference":
        return plot_baseline_vs_max_difference(outputs["baseline_vs_max_difference"], title=title, show=show, filename=filename)

    elif chart_id == "uncertainty_vs_aspirational":
        return plot_uncertainty_vs_aspirational(outputs["uncertainty"], outputs["aspirational_best_case"], title=title, show=show, filename=filename)

    elif chart_id == "feasibility_impact_matrix":
        return plot_feasibility_impact_matrix(title=title, show=show, filename=filename)
    
    else:
        raise ValueError(f"Unknown chart_id '{chart_id}'.")


def generate_figures(
    outputs: Dict[str, pd.DataFrame],
    chart_ids: Optional[List[str]] = None,
    show: bool = True,
    max_decarb_sensitivity_results: Optional[Dict[str, pd.DataFrame]] = None,
